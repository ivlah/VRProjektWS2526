  m_Name: 
  m_EditorClassIdentifier: 
  subtitleText: {fileID: 1865477880}
  backgroundPanel: {fileID: 0}
  normalFont: {fileID: 11400000, guid: 8fc650701739faf46a8e64664ec66891, type: 2}
  highlightFont: {fileID: 11400000, guid: 8583f08d08c314d309c3bdf643efc928, type: 2}
  normalColor: {r: 0.899371, g: 0.81301963, b: 0.4666547, a: 0.81960785}
  highlightColor: {r: 0.95, g: 0.1, b: 0.1, a: 1}
  highlightBold: 1
  highlightItalic: 0
  fadeInDuration: 0.2
  fadeOutDuration: 0.2
  autoPlay: 1
  entries:
  - label: Line 01
    text: "If your little squirrel were to ask you for something very, very prettily\u2014?"
    startTime: 12
    duration: 4
  - label: Line 02
    text: "Please, don\u2019t dismiss Krogstad."
    startTime: 17
    duration: 3
  - label: Line 03
    text: How?
    startTime: 41
    duration: 2
  - label: Line 04
    text: How hot it is in here, I am not feeling well...
    startTime: 100
    duration: 3
  - label: Line 05
    text: no, noo
    startTime: 105
    duration: 2
  - label: Line 06
    text: Please stay outside my love, I must learn dancing, I woud only embarrass
      myself...
    startTime: 160
    duration: 4
  - label: Line 07
    text: Are you going to work a bit more tonight?
    startTime: 182
    duration: 3
